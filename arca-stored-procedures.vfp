Function OnDelVincoli()
	Local i, cMsg
	cMsg = 'ComputerName : ' + GetComputerName(.F.)
	
	For i = Program(-1) To  1 Step -1
		cMsg = cMsg + Chr(13) + Chr(10) + Padr(i,3) + ' ' + Sys(16, i) + ' '
	Next
	
	Error_Handler(0, 0, cMsg, "Cancellazione record Private!Vincoli")
EndFunc

