** ------------------------------------------------------------------------------------------
** Conti

Trigger
Function OnUpdConti()
	Local cOldCodice, cNewCodice
	Local nOldWa

	If TYPE('NoTriggerOnUpdConti') != 'U' OR TYPE('NoTriggerOnUpd') != 'U'
		Return .T.
	Endif

	Private NoTriggerOnUpd
	NoTriggerOnUpd = .T.
	cOldCodice	= CURVAL('Codice')
	If !EMPTY(cOldCodice) AND !EMPTY(Codice) AND !(Codice == cOldCodice)

		nOldWa = SELECT(0)

		cNewCodice	= Codice

		Update Private!Anagrafe		SET Anagrafe.Contrabit	=	cNewCodice	WHERE	Anagrafe.Contrabit	==	cOldCodice
		Update Private!Anagrafe		SET Anagrafe.Contrpart	=	cNewCodice	WHERE	Anagrafe.Contrpart	==	cOldCodice
		Update Private!Banche		SET Banche.Conto			=	cNewCodice	WHERE	Banche.Conto			==	cOldCodice
		Update Private!Banche		SET Banche.ContoSbf		=	cNewCodice	WHERE	Banche.ContoSbf		==	cOldCodice
		Update Private!CspAna		SET CspAna.PDCCostoAA	=	cNewCodice	WHERE	CspAna.PDCCostoAA		==	cOldCodice
		Update Private!CspAna		SET CspAna.PDCCostoAO	=	cNewCodice	WHERE	CspAna.PDCCostoAO		==	cOldCodice
		Update Private!CspAna		SET CspAna.PDCFondoAA	=	cNewCodice	WHERE	CspAna.PDCFondoAA		==	cOldCodice
		Update Private!CspAna		SET CspAna.PDCFondoAO	=	cNewCodice	WHERE	CspAna.PDCFondoAO		==	cOldCodice
		Update Private!CspAna		SET CspAna.PDCImmob		=	cNewCodice	WHERE	CspAna.PDCImmob		==	cOldCodice
		Update Private!CspAna		SET CspAna.PDCMinVal		=	cNewCodice	WHERE	CspAna.PDCMinVal		==	cOldCodice
		Update Private!CspAna		SET CspAna.PDCPlusVal	=	cNewCodice	WHERE	CspAna.PDCPlusVal		==	cOldCodice
		Update Private!CspAna		SET CspAna.PDCRiserva	=	cNewCodice	WHERE	CspAna.PDCRiserva		==	cOldCodice
		Update Private!CspCatCn		SET CspCatCn.PDCCostoAA	=	cNewCodice	WHERE	CspCatCn.PDCCostoAA	==	cOldCodice
		Update Private!CspCatCn		SET CspCatCn.PDCCostoAO	=	cNewCodice	WHERE	CspCatCn.PDCCostoAO	==	cOldCodice
		Update Private!CspCatCn		SET CspCatCn.PDCFondoAA	=	cNewCodice	WHERE	CspCatCn.PDCFondoAA	==	cOldCodice
		Update Private!CspCatCn		SET CspCatCn.PDCFondoAO	=	cNewCodice	WHERE	CspCatCn.PDCFondoAO	==	cOldCodice
		Update Private!CspCatCn		SET CspCatCn.PDCImmob	=	cNewCodice	WHERE	CspCatCn.PDCImmob		==	cOldCodice
		Update Private!CspCatCn		SET CspCatCn.PDCMinVal	=	cNewCodice	WHERE	CspCatCn.PDCMinVal	==	cOldCodice
		Update Private!CspCatCn		SET CspCatCn.PDCPlusVal	=	cNewCodice	WHERE	CspCatCn.PDCPlusVal	==	cOldCodice
		Update Private!CspCatCn		SET CspCatCn.PDCRiserva	=	cNewCodice	WHERE	CspCatCn.PDCRiserva	==	cOldCodice
		Update Private!Ditta			SET Ditta.ContoCli		=	cNewCodice	WHERE	Ditta.ContoCli			==	cOldCodice
		Update Private!Ditta			SET Ditta.ContoFor		=	cNewCodice	WHERE	Ditta.ContoFor			==	cOldCodice
		Update Private!DocTran		SET DocTran.CodPDC		=	cNewCodice	WHERE	DocTran.CodPDC			==	cOldCodice
		Update Private!Integra		SET Integra.CodConto		=	cNewCodice	WHERE	Integra.CodConto		==	cOldCodice
		Update Private!RicVal		SET RicVal.CodConto		=	cNewCodice	WHERE	RicVal.CodConto		==	cOldCodice
		Update Private!Righe			SET Righe.CodConto		=	cNewCodice	WHERE	Righe.CodConto			==	cOldCodice
		Update Private!Righe			SET Righe.Contrpart		=	cNewCodice	WHERE	Righe.Contrpart		==	cOldCodice
		Update Private!Saldi			SET Saldi.CodConto		=	cNewCodice	WHERE	Saldi.CodConto			==	cOldCodice
		Update Private!Scadenze		SET Scadenze.ContoSbf	=	cNewCodice	WHERE	Scadenze.ContoSbf		==	cOldCodice
		Update Private!Scadenze		SET Scadenze.ContrBanca	=	cNewCodice	WHERE	Scadenze.ContrBanca	==	cOldCodice
		Update Private!Scadenze		SET Scadenze.EffAttivi	=	cNewCodice	WHERE	Scadenze.EffAttivi	==	cOldCodice
		Update Private!VincFatt		SET VincFatt.Conto		=	cNewCodice	WHERE	VincFatt.Conto			==	cOldCodice
		Update Private!Vincoli		SET Vincoli.Cassa			=	cNewCodice	WHERE	Vincoli.Cassa			==	cOldCodice
		Update Private!Vincoli		SET Vincoli.CIvaAcqCEE	=	cNewCodice	WHERE	Vincoli.CIvaAcqCEE	==	cOldCodice
		Update Private!Vincoli		SET Vincoli.DifAttCmb	=	cNewCodice	WHERE	Vincoli.DifAttCmb		==	cOldCodice
		Update Private!Vincoli		SET Vincoli.DifPasCmb	=	cNewCodice	WHERE	Vincoli.DifPasCmb		==	cOldCodice
		Update Private!Vincoli		SET Vincoli.Erario		=	cNewCodice	WHERE	Vincoli.Erario			==	cOldCodice
		Update Private!Vincoli		SET Vincoli.IvaAcq		=	cNewCodice	WHERE	Vincoli.IvaAcq			==	cOldCodice
		Update Private!Vincoli		SET Vincoli.IvaAcqCEE	=	cNewCodice	WHERE	Vincoli.IvaAcqCEE		==	cOldCodice
		Update Private!Vincoli		SET Vincoli.IvaOmaggio	=	cNewCodice	WHERE	Vincoli.IvaOmaggio	==	cOldCodice
		Update Private!Vincoli		SET Vincoli.IvaSos		=	cNewCodice	WHERE	Vincoli.IvaSos			==	cOldCodice
		Update Private!Vincoli		SET Vincoli.IvaVen		=	cNewCodice	WHERE	Vincoli.IvaVen			==	cOldCodice
		Update Private!Vincoli		SET Vincoli.PDCAbbAtt	=	cNewCodice	WHERE	Vincoli.PDCAbbAtt		==	cOldCodice
		Update Private!Vincoli		SET Vincoli.PDCAbbPass	=	cNewCodice	WHERE	Vincoli.PDCAbbPass	==	cOldCodice
		Update Private!Vincoli		SET Vincoli.PDCAcc		=	cNewCodice	WHERE	Vincoli.PDCAcc			==	cOldCodice
		Update Private!Vincoli		SET Vincoli.PDCEffAtt	=	cNewCodice	WHERE	Vincoli.PDCEffAtt		==	cOldCodice
		Update Private!Vincoli		SET Vincoli.PDCEffPass	=	cNewCodice	WHERE	Vincoli.PDCEffPass	==	cOldCodice
		Update Private!Vincoli		SET Vincoli.PDCInc		=	cNewCodice	WHERE	Vincoli.PDCInc			==	cOldCodice
		Update Private!Vincoli		SET Vincoli.PDCOmaggio	=	cNewCodice	WHERE	Vincoli.PDCOmaggio	==	cOldCodice
		Update Private!Vincoli		SET Vincoli.PDCPag		=	cNewCodice	WHERE	Vincoli.PDCPag			==	cOldCodice
		Update Private!Vincoli		SET Vincoli.Vendite		=	cNewCodice	WHERE	Vincoli.Vendite		==	cOldCodice
		Update Private!CauAuto		SET CauAuto.CodConto		=	cNewCodice	WHERE	CauAuto.CodConto		==	cOldCodice

		Select (nOldWa)

	Endif
Endfunc

Trigger
Function OnDelConti()

	If TYPE('NoTriggerOnDelConti') != 'U' OR TYPE('NoTriggerOnDel') != 'U'
		Return .T.
	Endif

	If EMPTY(Codice)
		Return .T.
	Endif

	Local cCodice
	Local nOldWa

	nOldWa = SELECT(0)

	cCodice = Codice
	Delete FROM Private!CauAuto WHERE CodConto == cCodice

	Select (nOldWa)

Endfunc

** ------------------------------------------------------------------------------------------
** Scadenze

Trigger
Function OnInsScadenze()

	If TYPE('NoTriggerOnInsScadenze') != 'U' OR TYPE('NoTriggerOnIns') != 'U'
		Return .T.
	Endif

	If Insoluto AND !Pagato								&& Se la scadenza in inserimento è insoluta e non pagata...
		OnScadenze(CodCF, +1, ImpEff)
	Endif

Endfunc

Trigger
Function OnUpdScadenze()

	If TYPE('NoTriggerOnUpdScadenze') != 'U' OR TYPE('NoTriggerOnUpd') != 'U'
		Return .T.
	Endif

	Local lEraInsoluta, lEraPagata, lSaraInsoluta, lSaraPagata

	lEraInsoluta 	= OldVal('Insoluto') 
	lEraPagata		= OldVal('Pagato')
	lSaraInsoluta 	= Insoluto 	
	lSaraPagata    = Pagato 

	Do Case
		Case (					 !lEraInsoluta) And (!lSaraPagata And  lSaraInsoluta)		&& registrazione insoluto
			OnScadenze(CodCF, +1,  ImpEff)
			
		Case (!lEraPagata And  lEraInsoluta) And (!lSaraPagata And !lSaraInsoluta)		&& elimino registrazione insoluto
			OnScadenze(CodCF, -1, -ImpEff)
		
		Case (!lEraPagata And  lEraInsoluta) And ( lSaraPagata And  lSaraInsoluta)		&& pagamento insoluto
			** niente

		Case ( lEraPagata And  lEraInsoluta) And (!lSaraPagata And  lSaraInsoluta)		&& elimino pagamento insoluto
			** niente
		
		Case (lEraPagata = lSaraPagata) And lEraInsoluta And lSaraInsoluta And ImpEff != OldVal('ImpEff') && modifico solo l'importo
			OnScadenze(CodCF, 0, ImpEff - OldVal('ImpEff'))
			
	EndCase

Endfunc

Trigger
Function OnDelScadenze()

	If TYPE('NoTriggerOnDelScadenze') != 'U' OR TYPE('NoTriggerOnDel') != 'U'
		Return .T.
	Endif

	Local nIdRagg

	If OLDVAL('Insoluto') AND !OLDVAL('Pagato')			&& Se la scadenza in cancellazione era insoluta e non pagata...
		=OnScadenze(CodCF, -1, -OLDVAL('ImpEff'))
	Endif

Endfunc

STATIC
Function OnScadenze(cCodCF, nDeltaNumIns, nDeltaValIns)

	** Deve eseguire l'update degli insoluti soltanto se non si tratta di una scadenza madre.
	If !(TipoAcc == 'M')
		Update Private!Anagrafe ;
			SET ;
			Anagrafe.NumIns = Anagrafe.NumIns + nDeltaNumIns, ;
			Anagrafe.TotIns = Anagrafe.TotIns + nDeltaValIns ;
			WHERE Anagrafe.Codice == cCodCF
	Endif

Endfunc

** ------------------------------------------------------------------------------------------
** CspMov

Function OnDelCspMov()

	If TYPE('NoTriggerOnDelCspMov') != 'U' OR TYPE('NoTriggerOnDel') != 'U'
		Return .T.
	Endif

	If EMPTY(CspMov.Cespite)
		Return .T.
	Endif

	** Il Test su tipocau == 5  e` superfluo in quanto la simulazione, va settata solo per gli ammortamenti
	** (tipo 5 appunto), ma siccome non sono sicuro di aver fatto tutto giusto, in questo modo mi paro le
	** chiappe ed evito di non aggiornare angrafiche per aver lasciato un TRUE su simulato di un movimento
	** che non sia di ammortamento!
	If Simulato AND TipoCau == 5
		Return .T.
	Endif

	Do CASE
		Case TipoCau == 1			&& Acquisizione
			Update Private!CspAna SET 		;
				CspAna.DataDecorr = {//}, 	;
				CspAna.DataUtiliz = {//}, 	;
				CspAna.CodFor 	 	= '',	 	;
				CspAna.DataAcq 	= {//},	;
				CspAna.NumRifAcq 	= '',	 	;
				CspAna.Protocollo = '',    ;
				CspAna.IdMovAcq   = $0     ;
				WHERE CspAna.Codice = CspMov.Cespite

		Case TipoCau == 2			&& Dismissione
			Update Private!CspAna SET		;
				CspAna.CodCli		= '', 	;
				CspAna.DataVen		= {//},	;
				CspAna.NumRifVen	= '',		;
				CspAna.IdMovVen   = $0     ;
				WHERE CspAna.Codice = CspMov.Cespite
	Endcase

	**		LOCAL nOldWA
	**		LOCAL cTmpMovAlias
	**		LOCAL dUltAmm
	**		LOCAL yId
	**		LOCAL lDeleteRec
	**		lDeleteRec = .F.
	**		dUltAmm = {//}
	**		nOldWa = SELECT(0)
	**		IF !Simulato
	**			IF !USED('CspAna')
	**				USE Private!CspAna ALIAS CspAna IN 0 AGAIN
	**			ENDIF
	**			** Se si tratta di un ammortamento bisogna prestare attenzione
	**			** agli eventuali aggiornamenti che ha eseguito in CspAna! (es. DataUltimoAmmortamento)
	**			DO CASE
	**	**				CASE TipoCau == 5
	**	**					yId = ID
	**	**					IF SEEK(Cespite, 'CspAna', 'Codice')
	**	**						IF CspAna.DataUltAmm == DataReg
	**	**							cTmpMovAlias = GetLegalFileName()
	**	**							SELECT DataReg FROM Private!CspMov WHERE Cespite == CspAna.Codice AND TipoCau == 5 AND ID != yID INTO CURSOR (cTmpMovAlias) ORDER BY DataReg DESC NOFILTER
	**	**							IF _TALLY > 0
	**	**								LOCATE
	**	**								dUltAmm = DataReg
	**	**							ENDIF
	**	**							USE IN (cTmpMovAlias)
	**	**							REPLACE CspAna.DataUltAmm WITH dUltAmm IN CspAna
	**	**							SELECT (nOldWA)
	**	**							lDeleteRec = .T.
	**	**						ELSE
	**	**							xMessageBox("E` possibile cancellare solo l'ultimo ammortamento eseguito!")
	**	**						ENDIF
	**	**					ENDIF

	**	** Acquisizione
	**				CASE TipoCau == 1

	**					IF SEEK(Cespite, 'CspAna', 'Codice')
	**						REPLACE cspAna.DataDecorr 	WITH {//}
	**						REPLACE cspAna.DataUtiliz 	WITH {//}
	**						REPLACE cspAna.CodFor 	 	WITH SPACE(6)
	**						REPLACE cspAna.DataAcq 	 	WITH {//}
	**						REPLACE cspana.NumRifAcq 	WITH SPACE(10)
	**						SELECT (nOldWA)
	**						lDeleteRec = .T.
	**	**					ELSE
	**	**						 xMessageBox("Non e` possibile aggioirnare l'anagrafica del cespite!")
	**					ENDIF
	**	** Dismissione
	**				CASE TipoCau == 2
	**					IF SEEK(Cespite, 'CspAna', 'Codice')
	**						REPLACE cspAna.CodCli		WITH SPACE(6)
	**						REPLACE cspAna.DataVen		WITH {//}
	**						REPLACE cspana.NumRifVen	WITH SPACE(10)
	**						SELECT (nOldWA)
	**						lDeleteRec = .T.
	**	**					ELSE
	**	**						 xMessageBox("Non e` possibile aggioirnare l'anagrafica del cespite!")
	**					ENDIF
	**			ENDCASE
	**		ELSE
	**			lDeleteRec = .T.
	**		ENDIF
	**		** Nel caso lDeleteRec risulti FALSE il trigger fallisce, e ne viene trappato l'errore (1539) nell'error event della browse form!
	**		RETURN lDeleteRec
Endfunc


** ------------------------------------------------------------------------------------------
** MagArt

**	TRIGGER
**	FUNCTION OnInsMagArt()

**		IF TYPE('NoTriggerOnInsMagArt') != 'U' OR TYPE('NoTriggerOnIns') != 'U'
**			RETURN .T.
**		ENDIF
**
**	ENDFUNC

Trigger
Function OnDelMagArt()

	If TYPE('NoTriggerOnDelMagArt') != 'U' OR TYPE('NoTriggerOnDel') != 'U'
		Return .T.
	Endif

	If EMPTY(Codice)
		Return .T.
	Endif
	Local cCodice
	Local nOldWa

	nOldWa = SELECT(0)

	cCodice = Codice
	Delete FROM Private!MagAlias	WHERE	CodiceArti			   ==	cCodice
	Delete FROM Private!MagLang	WHERE	CodiceArti			   ==	cCodice
	Delete FROM Private!Listini	WHERE	CodiceArti			   ==	cCodice
	Delete FROM Private!MagGiac	WHERE	Articolo				   ==	cCodice
	Delete FROM Private!MagGiacS	WHERE	Articolo				   ==	cCodice
	Delete FROM Private!CodAlt		WHERE	CodiceArti			   ==	cCodice
	Delete FROM Private!DistBase	WHERE	DistBase.CodComp	   ==	cCodice
	Delete FROM Private!DistBase	WHERE	DistBase.CodPadre	   ==	cCodice
	Delete FROM Private!DocRig		WHERE	DocRig.CodiceArti	   ==	cCodice
	Delete FROM Private!MagOI		WHERE	MagOI.Articolo		   ==	cCodice
	Delete FROM Private!MagOIL 	WHERE	MagOIL.Articolo	   ==	cCodice
	Delete FROM Private!PrdGiac	WHERE	PrdGiac.Articolo	   ==	cCodice
	Delete FROM Private!PrdMrp		WHERE	PrdMrp.Articolo	   ==	cCodice
	Delete FROM Private!PrdMrp		WHERE	PrdMrp.IndotDaArt	   ==	cCodice
	Delete FROM Private!PrdSim		WHERE	PrdSim.CodiceArti	   ==	cCodice
	Delete FROM Private!MagImage	WHERE	MagImage.CodiceArti	==	cCodice
	Delete FROM Private!MagMov		WHERE	MagMov.CodiceArti	   ==	cCodice

	Delete FROM Private!RcRighe	WHERE	CodiceArti	   		==	cCodice
	Delete FROM Private!TpCicli	WHERE	Articolo	   			==	cCodice
	Delete FROM Private!Lotti		WHERE	CodiceArti	   		==	cCodice
	Delete FROM Private!MagGiacL	WHERE	Articolo	   			==	cCodice
	Delete FROM Private!MagGiacS	WHERE	Articolo	   			==	cCodice
	Delete FROM Private!AmOrderTemplate	WHERE	CodiceArti	   ==	cCodice
	
	Select (nOldWa)

Endfunc

Trigger
Function OnUpdMagArt()

	Local cOldCodice, cNewCodice
	Local nOldWa

	If TYPE('NoTriggerOnUpdMagArt') != 'U' OR TYPE('NoTriggerOnUpd') != 'U'
		Return .T.
	Endif

	If TipoParte != OLDVAL('TipoParte')
		Local cTipoParte, cCodArt
		cTipoParte = TipoParte
		cCodArt	  = Codice
		Update Private!DistBase SET TipoParte = cTipoParte WHERE CodComp == cCodArt
	Endif

	cOldCodice	= CURVAL('Codice')
	If !EMPTY(cOldCodice) AND !EMPTY(Codice) AND !(Codice == cOldCodice)
		Private NoTriggerOnUpdMagMov

		nOldWa = SELECT(0)

		cNewCodice	= Codice

		Update Private!CodAlt		SET CodAlt.CodiceArti	=	cNewCodice	WHERE	CodAlt.CodiceArti		==	cOldCodice
		Update Private!DistBase		SET DistBase.CodComp		=	cNewCodice	WHERE	DistBase.CodComp		==	cOldCodice
		Update Private!DistBase		SET DistBase.CodPadre	=	cNewCodice	WHERE	DistBase.CodPadre		==	cOldCodice
		Update Private!DocRig		SET DocRig.CodiceArti	=	cNewCodice	WHERE	DocRig.CodiceArti		==	cOldCodice
		Update Private!Listini		SET Listini.CodiceArti	=	cNewCodice	WHERE	Listini.CodiceArti	==	cOldCodice
		Update Private!MagAlias		SET MagAlias.CodiceArti	=	cNewCodice	WHERE	MagAlias.CodiceArti	==	cOldCodice
		Update Private!MagGiac		SET MagGiac.Articolo		=	cNewCodice	WHERE	MagGiac.Articolo		==	cOldCodice
		Update Private!MagGiacS		SET MagGiacS.Articolo	=	cNewCodice	WHERE	MagGiacS.Articolo		==	cOldCodice
		Update Private!MagOI			SET MagOI.Articolo		=	cNewCodice	WHERE	MagOI.Articolo			==	cOldCodice
		Update Private!MagOIL		SET MagOIL.Articolo		=	cNewCodice	WHERE	MagOIL.Articolo		==	cOldCodice
		Update Private!PrdGiac		SET PrdGiac.Articolo		=	cNewCodice	WHERE	PrdGiac.Articolo		==	cOldCodice
		Update Private!PrdMrp		SET PrdMrp.Articolo		=	cNewCodice	WHERE	PrdMrp.Articolo		==	cOldCodice
		Update Private!PrdMrp		SET PrdMrp.IndotDaArt	=	cNewCodice	WHERE	PrdMrp.IndotDaArt		==	cOldCodice
		Update Private!PrdSim		SET PrdSim.CodiceArti	=	cNewCodice	WHERE	PrdSim.CodiceArti		==	cOldCodice
		Update Private!MagImage		SET MagImage.CodiceArti	=	cNewCodice	WHERE	MagImage.CodiceArti	==	cOldCodice
		Update Private!MagLang		SET MagLang.CodiceArti	=	cNewCodice	WHERE	MagLang.CodiceArti	==	cOldCodice
		** Impedisco al trigger di MagMov di eseguire eventuali storni che mi andrebbero a creare un record in Maggiac
		** con il vecchio codice articolo!
		NoTriggerOnUpdMagMov = .T.
		Update Private!MagMov		SET MagMov.CodiceArti	=	cNewCodice	WHERE	MagMov.CodiceArti		==	cOldCodice

		Select (nOldWa)

	Endif

Endfunc

** ------------------------------------------------------------------------------------------
** TpFasi
Trigger
Function OnUpdTpFasi()

	If TYPE('NoTriggerOnUpdTpFasi') != 'U' OR TYPE('NoTriggerOnUpd') != 'U'
		Return .T.
	Endif

	If ConsFisso != OLDVAL('ConsFisso')
		Local lConsFisso, cCodFase
		lConsFisso = ConsFisso
		cCodFase  = Codice
		Update Private!TpCicli  SET ConsFisso = lConsFisso WHERE CodFase == cCodFase
		*		UPDATE Private!TpLpCicl SET ConsFisso = lConsFisso WHERE CodFase == cCodFase AND Stato == 1
	Endif

Endfunc


** ------------------------------------------------------------------------------------------
** MagGrp
Trigger
Function OnUpdMagGrp()

	Local cOldCodice, cNewCodice
	Local nOldWa

	If TYPE('NoTriggerOnUpdMagGrp') != 'U' OR TYPE('NoTriggerOnUpd') != 'U'
		Return .T.
	Endif

	cOldCodice	= CURVAL('Codice')
	If !EMPTY(cOldCodice) AND !EMPTY(Codice) AND !(Codice == cOldCodice)

		nOldWa = SELECT(0)
		cNewCodice	= Codice

		Update Private!MagArt		SET MagArt.Gruppo		=	cNewCodice	WHERE	MagArt.Gruppo		==	cOldCodice
		Update Private!DocRig		SET DocRig.Gruppo		=	cNewCodice	WHERE	DocRig.Gruppo		==	cOldCodice
		Update Private!Listini		SET Listini.GruppoMag	=	cNewCodice	WHERE	Listini.GruppoMag	==	cOldCodice
		Update Private!MagMov		SET MagMov.Gruppo		=	cNewCodice	WHERE	MagMov.Gruppo		==	cOldCodice

		Select (nOldWa)

	Endif

Endfunc

** ------------------------------------------------------------------------------------------
** --- Classi di magazzino
Trigger
Function OnUpdMagCls()

	Local cOldCodice, cNewCodice
	Local nOldWa

	If TYPE('NoTriggerOnUpdMagCls') != 'U' OR TYPE('NoTriggerOnUpd') != 'U'
		Return .T.
	Endif

	cOldCodice	= CURVAL('Codice')
	If !EMPTY(cOldCodice) AND !EMPTY(Codice) AND !(Codice == cOldCodice)

		nOldWa = SELECT(0)

		cNewCodice	= Codice

		Update Private!MagArt	SET MagArt.Classe	= cNewCodice	WHERE MagArt.Classe == cOldCodice
		Update Private!DocRig	SET DocRig.Classe	= cNewCodice	WHERE DocRig.Classe == cOldCodice
		Update Private!MagMov	SET MagMov.Classe	= cNewCodice	WHERE MagMov.Classe == cOldCodice
		Select (nOldWa)

	Endif
Endfunc

** ------------------------------------------------------------------------------------------
** MagMov
** Attualmente gestiscono solo la variazione di Articolo
** Esercizio Magazzino
** Non è gestita la variazione dei flag di movimentazione...
** Ci dovrebbe pensare il programma di ins/modifica doc.

Trigger
Function OnInsMagMov()

	If TYPE('NoTriggerOnInsMagMov') != 'U' OR TYPE('NoTriggerOnIns') != 'U'
		Return .T.
	Endif

	OnMagMov(		 	;
		esercizio, 		;
		Magazzino,		;
		CodiceArti,		;
		Lotto,        	;
		Quantita,   	;
		QuantitaRe, 	;
		Valore        	)
Endfunc

Trigger
Function OnDelMagMov()

	If TYPE('NoTriggerOnDelMagMov') != 'U' OR TYPE('NoTriggerOnDel') != 'U'
		Return .T.
	Endif

	OnMagMov( 						;
		CURVAL('Esercizio' ),	;
		CURVAL('Magazzino' ),	;
		CURVAL('CodiceArti'),	;
		CURVAL('Lotto'     ), 	;
		-CURVAL('Quantita'  ), 	;
		-CURVAL('QuantitaRe'), 	;
		-CURVAL('Valore'    )  	)
Endfunc

Trigger
Function OnUpdMagMov()

	If TYPE('NoTriggerOnUpdMagMov') != 'U' OR TYPE('NoTriggerOnUpd') != 'U'
		Return .T.
	Endif

	If Esercizio  	== CURVAL('Esercizio' )  AND ;
		Magazzino  	== CURVAL('Magazzino' )  AND ;
		CodiceArti 	== CURVAL('CodiceArti')  AND ;
		Lotto      	== CURVAL('Lotto'     )

		OnMagMov(										;
			esercizio, 									;
			Magazzino,									;
			CodiceArti,									;
			Lotto,                              ;
			Quantita   - CURVAL('Quantita'  ),	;
			QuantitaRe - CURVAL('QuantitaRe'), 	;
			Valore     - CURVAL('Valore'    ) 	)
	Else
		OnDelMagMov()
		OnInsMagMov()
	Endif
Endfunc

STATIC
Function OnMagMov(cEsercizio, cMagazzino, cArticolo, cLotto, nDeltaQta, nDeltaQtaRe, nDeltaVal)

	Local lChgQta, lChgVal, lChgOI, lChgOIL, lChgLot, nDeltaValOI
	Local cKeyToSearch
	Local ARRAY aEser[1]
	Local oMagMovRec

	Scatter NAME oMagMovRec

	If !USED('MagGiac')
		Use PRIVATE!MagGiac IN 0
		CursorSetProp('Buffering', 3, 'MagGiac')
	Endif

	lChgQta = (nDeltaQta   != 0) .AND. (!EMPTY(oMagMovRec.QtaCar) .OR. !EMPTY(oMagMovRec.QtaScar) .OR. !EMPTY(oMagMovRec.QtaTCar) .OR. !EMPTY(oMagMovRec.QtaTScar) .OR. !EMPTY(oMagMovRec.QtaRet))
	lChgVal = (nDeltaVal   != 0) .AND. (!EMPTY(oMagMovRec.ValCar) .OR. !EMPTY(oMagMovRec.ValScar) .OR. !EMPTY(oMagMovRec.ValTCar) .OR. !EMPTY(oMagMovRec.ValTScar) .OR. !EMPTY(oMagMovRec.ValRet))
	lChgOI  = (nDeltaQtaRe != 0) .AND. (!EMPTY(oMagMovRec.Ordin ) .OR. !EMPTY(oMagMovRec.Impegn))
	lChgLot = (nDeltaQta   != 0) .AND. !EMPTY(cLotto) .AND. (!EMPTY(oMagMovRec.QtaCar) .OR. !EMPTY(oMagMovRec.QtaScar) .OR. !EMPTY(oMagMovRec.QtaTCar) .OR. !EMPTY(oMagMovRec.QtaTScar) .OR. !EMPTY(oMagMovRec.QtaRet))
	lChgOIL = (nDeltaQtaRe != 0) .AND. !EMPTY(cLotto) .AND. (!EMPTY(oMagMovRec.Ordin ) .OR. !EMPTY(oMagMovRec.Impegn))

	If (lChgQta .OR. lChgVal)

		cKeyToSearch = cEsercizio + cMagazzino + cArticolo

		Seek cKeyToSearch ORDER TAG Codice IN MagGiac
		If !FOUND('MagGiac')
			Flock('MagGiac')
			Seek cKeyToSearch ORDER TAG Codice IN MagGiac
			If !FOUND('MagGiac')
				Insert INTO MagGiac (esercizio, Magazzino, Articolo) VALUES (cEsercizio, cMagazzino, cArticolo)
			Endif
			Unlock IN MagGiac
		Endif

		If RLOCK('MagGiac')
			If lChgQta
				Replace 																						;
					ProgQtaCar WITH ProgQtaCar + (oMagMovRec.QtaCar     * nDeltaQta),	;
					ProgQtaSca WITH ProgQtaSca + (oMagMovRec.QtaScar    * nDeltaQta),	;
					ProgQtaTCa WITH ProgQtaTCa + (oMagMovRec.QtaTCar    * nDeltaQta),	;
					ProgQtaTSc WITH ProgQtaTSc + (oMagMovRec.QtaTScar   * nDeltaQta),	;
					ProgQtaRet WITH ProgQtaRet + (oMagMovRec.QtaRet     * nDeltaQta), ;
					Timestamp  WITH DATETIME()														;
					IN MagGiac
			Endif
			If lChgVal
				Replace 																						;
					ProgValCar WITH ProgValCar + (oMagMovRec.ValCar     * nDeltaVal),	;
					ProgValSca WITH ProgValSca + (oMagMovRec.ValScar    * nDeltaVal),	;
					ProgValTCa WITH ProgValTCa + (oMagMovRec.ValTCar    * nDeltaVal),	;
					ProgValTSc WITH ProgValTSc + (oMagMovRec.ValTScar   * nDeltaVal),	;
					ProgValRet WITH ProgValRet + (oMagMovRec.ValRet     * nDeltaVal), ;
					Timestamp  WITH DATETIME()														;
					IN MagGiac
			Endif
			Unlock IN MagGiac
		Endif

	Endif

	If (lChgOI)

		Local yValoreOrdImp

		If oMagMovRec.Quantita != 0
			yValoreOrdImp = ROUND(((oMagMovRec.Valore/oMagMovRec.Quantita) * nDeltaQtaRe), 0)
		Else
			yValoreOrdImp = $0
		Endif

		If !USED('MagOI')
			Use PRIVATE!MagOI IN 0
			CursorSetProp('Buffering', 3, 'MagOI')
		Endif

		cKeyToSearch = cMagazzino + cArticolo

		Seek cKeyToSearch ORDER TAG Codice IN MagOI
		If !FOUND('MagOI')
			Flock('MagOI')
			Seek cKeyToSearch ORDER TAG Codice IN MagOI
			If !FOUND('MagOI')
				Insert INTO MagOI (Magazzino, Articolo) VALUES (cMagazzino, cArticolo)
			Endif
			Unlock IN MagOI
		Endif

		If LOCK('MagOI')
			Replace 																				;
				Ordinato  WITH Ordinato  + (oMagMovRec.Ordin  * nDeltaQtaRe),	;
				Impegnato WITH Impegnato + (oMagMovRec.Impegn * nDeltaQtaRe),	;
				ValOrd	 WITH ValOrd    + (oMagMovRec.Ordin  * yValoreOrdImp),;
				ValImp	 WITH ValImp    + (oMagMovRec.Impegn * yValoreOrdImp),;
				Timestamp WITH DATETIME() 													;
				IN MagOI

			If EMPTY(MagOI.Ordinato) .AND. EMPTY(MagOI.Impegnato) .AND. EMPTY(MagOI.ValOrd) .AND. EMPTY(MagOI.ValImp)
				Delete IN MagOI
			Endif

			Unlock IN MagOI
		Endif

	Endif

&& Aggiorna giacenze per lotto
	If (lChgLot)

		If !USED('MagGiacL')
			Use PRIVATE!MagGiacL IN 0
			CursorSetProp('Buffering', 3, 'MagGiacL')
		Endif

		cKeyToSearch = cMagazzino + cArticolo + PADR(cLotto, 20, ' ')

		Seek cKeyToSearch ORDER TAG Codice IN MagGiacL
		If !FOUND('MagGiacL')
			Flock('MagGiacL')
			Seek cKeyToSearch ORDER TAG Codice IN MagGiacL
			If !FOUND('MagGiacL')
				Insert INTO MagGiacL (Magazzino, Articolo, Lotto) VALUES (cMagazzino, cArticolo, PADR(cLotto, 20, ' '))
			Endif
			Unlock IN MagGiacL
		Endif

		If RLOCK('MagGiacL')
			Replace 																					;
				ProgQtaCar WITH ProgQtaCar + (oMagMovRec.QtaCar     * nDeltaQta),	;
				ProgQtaSca WITH ProgQtaSca + (oMagMovRec.QtaScar    * nDeltaQta),	;
				ProgQtaTCa WITH ProgQtaTCa + (oMagMovRec.QtaTCar    * nDeltaQta),	;
				ProgQtaTSc WITH ProgQtaTSc + (oMagMovRec.QtaTScar   * nDeltaQta),	;
				ProgQtaRet WITH ProgQtaRet + (oMagMovRec.QtaRet     * nDeltaQta),	;
				TimeStamp  WITH DATETIME() 													;
				IN MagGiacL

			Unlock IN MagGiacL
		Endif

	Endif

&& Aggiorna ordinato/impegnato per lotto
	If (lChgOIL)

		If !USED('MagOIL')
			Use PRIVATE!MagOIL IN 0
			CursorSetProp('Buffering', 3, 'MagOIL')
		Endif

		cKeyToSearch = cMagazzino + cArticolo + cLotto

		Seek cKeyToSearch ORDER TAG Codice IN MagOIL
		If !FOUND('MagOIL')
			Flock('MagOIL')
			Seek cKeyToSearch ORDER TAG Codice IN MagOIL
			If !FOUND('MagOIL')
				Insert INTO MagOIL (Magazzino, Articolo, Lotto) VALUES (cMagazzino, cArticolo, cLotto)
			Endif
			Unlock IN MagOIL
		Endif

		If LOCK('MagOIL')
			Replace 																				;
				Ordinato  WITH Ordinato  + (oMagMovRec.Ordin  * nDeltaQtaRe),	;
				Impegnato WITH Impegnato + (oMagMovRec.Impegn * nDeltaQtaRe),	;
				Timestamp WITH DATETIME() 													;
				IN MagOIL

			If EMPTY(MagOIL.Ordinato) .AND. EMPTY(MagOIL.Impegnato)
				Delete IN MagOIL
			Endif

			Unlock IN MagOIL
		Endif

	Endif

Endfunc


** --------------------------------------------------------------------------------------------------------
** DocTes

Trigger
Function OnDelDocTes

	If TYPE('NoTriggerOnDelDocTes') != 'U' OR TYPE('NoTriggerOnDel') != 'U'
		Return .T.
	Endif

	Local nIDTestaDoc
	nIDTestaDoc = ID
	Delete FROM Private!DocTran  WHERE ID_Doc   == nIDTestaDoc
	Delete FROM Private!Intra 	  WHERE ID_Doc   == nIDTestaDoc AND Transit
	Delete FROM Private!Scadenze WHERE ID_Doc   == nIDTestaDoc AND Transit

	** Inizio modifiche 12/12/2000 mc & rv

	**DELETE FROM Private!DocRig   WHERE ID_Testa == nIDTestaDoc

	If !USED('_DocRig4Trg_')
		Use Private!DocRig ALIAS _DocRig4Trg_ AGAIN ORDER ID_Testa IN 0
	Endif

	** Nel Caso in cui nIDTestaDoc = 0 la procedura dava errore
	** Aggiunto AND !EOF(...) e chiusura alias alla fine
	Seek nIDTestaDoc IN _DocRig4Trg_
	Do WHILE _DocRig4Trg_.ID_Testa = nIDTestaDoc AND !EOF('_DocRig4Trg_')
		Delete  IN _DocRig4Trg_
		Skip +1 IN _DocRig4Trg_
	Enddo

	Use IN _DocRig4Trg_

Endfunc

** --------------------------------------------------------------------------------------------------------
** DocRig

Trigger
Function OnDelDocRig()

	If TYPE('NoTriggerOnDelDocRig') != 'U' OR TYPE('NoTriggerOnDel') != 'U'
		Return .T.
	Endif

	Local nIDRigaDoc
	nIDRigaDoc = ID

	**	DELETE FROM Private!MagMov WHERE ID_DocRig = nIDRigaDoc

	** Inizio modifiche 12/12/2000 mc & rv

	If !USED('_MagMov4Trg_')
		Use Private!MagMov ALIAS _MagMov4Trg_ AGAIN ORDER Id_DocRig IN 0
	Endif

	** Nel Caso in cui nIDRigaDoc = 0 la procedura dava errore
	** Aggiunto AND !EOF(...) e chiusura alias alla fine
	Seek nIDRigaDoc IN _MagMov4Trg_
	Do WHILE _MagMov4Trg_.Id_DocRig = nIDRigaDoc AND !EOF('_MagMov4Trg_')
		Delete  IN _MagMov4Trg_
		Skip +1 IN _MagMov4Trg_
	Enddo

	Use IN _MagMov4Trg_

Endfunc

