#INCLUDE "INCLUDE\FACILE.H"

** ------------------------------------------------------------------------------------------
** TRIGGERS
** ------------------------------------------------------------------------------------------

** ------------------------------------------------------------------------------------------
** Teste

Trigger
Function OnDelTeste()

	Local yID, nOldWa

	If TYPE('NoTriggerOnDelTeste') != 'U' OR TYPE('NoTriggerOnDel') != 'U'
		Return .T.
	Endif

	nOldWa = SELECT(0)

	yID = ID

	Delete FROM Private!Righe		WHERE ID_Testa 		= yID
	Delete FROM Private!Scadenze	WHERE ID_Pnota 		= yID
	Delete FROM Private!Intra		WHERE ID_Pnota 		= yID
	Delete FROM Private!Rit_Mov		WHERE Ft_IDPnota 		= yID
	Delete FROM Private!CanTeste	WHERE ID_Pnota 		= yID
	Delete FROM Private!RrTes   	WHERE ID_PnTeste 		= yID

	Select (nOldWa)

Endfunc

** ------------------------------------------------------------------------------------------
** Righe

Trigger
Function OnInsRighe()

	If TYPE('NoTriggerOnInsRighe') != 'U' OR TYPE('NoTriggerOnIns') != 'U'
		Return .T.
	Endif

	Local oRg

	** N.B.: La WorkArea corrente viene salvata da OnRighe()

	Scatter MEMO NAME oRg
	=OnRighe(oRg)

Endfunc

Trigger
Function OnUpdRighe()

	If TYPE('NoTriggerOnUpdRighe') != 'U' OR TYPE('NoTriggerOnUpd') != 'U'
		Return .T.
	Endif

	** N.B.: La WorkArea corrente viene salvata da OnRighe() (chiamato da OnDelRighe() e OnInsRighe())

	=OnDelRighe()
	=OnInsRighe()

Endfunc

Trigger
Function OnDelRighe()

	If TYPE('NoTriggerOnDelRighe') != 'U' OR TYPE('NoTriggerOnDel') != 'U'
		Return .T.
	Endif

	Local oRg, nRecNoScad, lContabil, nImportoPag, lPagato, dDataPag, ;
		lPortafog, lSBF, lInsoluto, nIdRagg
	Local yId_Testa

	Delete FROM Private!CspMov WHERE CspMov.IdMovCon == Righe.ID

	** Cancello eventuale movimento di rateo/risconto
	Delete FROM Private!RrRig WHERE Id_RatRis == Righe.ID

	** Elimino il collegamento con l'eventuale movimento di storno di rateo/risconto
	If !USED('RrRig')
		Use Private!RrRig IN 0
	Endif
	Seek Righe.Id ORDER TAG Id_Storno IN RrRig
	If FOUND('RrRig')
		Replace Id_Storno WITH $0 IN RrRig
	Endif

	** Cancello l'eventuale riga di pagamento nei movimenti di ritenuta
	** NOTA: in modifica del movimento contabile la riga viene cancellata e ricreata con lo stesso Id;
	** in questo caso non devo cancellare e ricreare anche la riga di pagamento del movimento di ritenuta d'acconto,
	** altrimenti perdo le modifiche fatte e l'eventuale data di versamento.
	** Se, invece, sto proprio cancellando la riga del movimento contabile, allora è correto cancellare anche la riga
	** di pagamento nel movimento di ritenuta d'acconto.
	** Distinguo i due casi in funzione dell'esistenza della variabile NoTriggerOnDelRitMovR.
	If TYPE('NoTriggerOnDelRitMovR') != 'U'
	Else
		If !USED('Rit_MovR')
			Use Private!Rit_MovR IN 0
		Endif
		Seek Righe.Id ORDER TAG Id_Righe IN Rit_MovR
		If FOUND('Rit_MovR')
			Delete IN Rit_MovR
		Endif
	Endif


	** N.B.: La WorkArea corrente viene salvata da OnRighe()

	Select Righe
	Scatter MEMO NAME oRg

	oRg.TipoRiga	=  OLDVAL('TipoRiga',	'Righe')
	oRg.Causale		=  OLDVAL('Causale',   	'Righe')
	oRg.ImportoLit	= -OLDVAL('Importolit',	'Righe')
	oRg.CodiceCF	=  OLDVAL('CodiceCF',	'Righe')
	oRg.CodConto	=  OLDVAL('CodConto',	'Righe')
	oRg.DareFlag	=  OLDVAL('DareFlag',	'Righe')
	oRg.SoloIva		=  OLDVAL('SoloIva',		'Righe')
	oRg.Imponibile	= -OLDVAL('Imponibile',	'Righe')
	oRg.CodIva		=  OLDVAL('CodIva',		'Righe')
	oRg.DataReg		=  OLDVAL('DataReg',		'Righe')
	oRg.EsReg		=  OLDVAL('EsReg',		'Righe')
	oRg.DataComp	=  OLDVAL('DataComp',	'Righe')
	oRg.EsComp		=  OLDVAL('EsComp',		'Righe')
	oRg.CodReg		=  OLDVAL('CodReg',		'Righe')
	oRg.DataComIva	=  OLDVAL('DataComIva',	'Righe')
	oRg.TipoFatt	=  OLDVAL('TipoFatt',	'Righe')

	** Se la riga da cancellare è una scadenza prelevata o contabilizzata !EMPTY(IDScad)
	** ed è effettivamente da cancellare ripristino l'importo prelevato della scadenza

	If !EMPTY(oRg.IdScad) AND DELETED()
		If !USED('Scadenze')
			Use Private!Scadenze IN 0
		Endif
		Seek oRg.IdScad ORDER TAG Id IN Scadenze

		** Scadenze presenta un Table buffering per cui testo se è cambiato qualche campo per effetto del prelievo in PN.
		** Il caso : Modifico un movimento cancellando una riga di scadenza prelevata e la riprelevo nella stessa sessione.
		** Devo quindi evitare che lo storno dovuto alla cancellazione annulli l'effetto dell'aggiornamento del prelievo.
		If FOUND('Scadenze') AND !(('2' $ GETFLDSTATE(-1, 'Scadenze')) OR ('4' $ GETFLDSTATE(-1, 'Scadenze')))

			** Tolgo il flag di contabilizzato e pagato se è una registrazione di contabiliz.
			If oRg.TipoCau == 'C'
				*!*			REPLACE Contabil WITH .F., ContrBanca WITH '' IN Scadenze
				Replace Contabil WITH .F. IN Scadenze

				** Nel caso la contabilizzazione abbia messo pagato .T. riporto la scadenza come non pagata
				If Scadenze.Pagato
					Replace	ImportoPag WITH 0, ;
						Pagato WITH .F., ;
						DataPag WITH CTOD('') ;
						IN Scadenze
				Endif

				If Scadenze.Portafog
					Replace Portafog WITH .F., EffAttivi WITH '' IN Scadenze
				Endif
				If Scadenze.SBF
					Replace SBF WITH .F., ContoSbf WITH '' IN Scadenze
				Endif

			Endif

			** Se è un incasso annullo l'importo pagato, il flag e la data di pagamento
			If oRg.TipoCau $ 'AB'
				Replace	ImportoPag WITH (ABS(Scadenze.ImportoPag) - ABS(oRg.ImportoVal)) * SIGN(Scadenze.ImportoPag), ;
					Pagato WITH .F., ;
					DataPag WITH CTOD('') ;
					IN Scadenze
			Endif

			** Tolgo il flag di insoluto se è una registrazione di insoluto
			If oRg.TipoCau == 'D'
				Replace Insoluto WITH .F. IN Scadenze
			Endif

			** Reimposto anche i flag sulla scadenza madre
			*			IF !EMPTY(nIdRagg)
			If !EMPTY(Scadenze.IdRagg)
				nIdRagg = Scadenze.IdRagg
				Set ORDER TO TAG IdRagg IN Scadenze
				nRecNoScad = RECNO('Scadenze')

				lContabil	= Scadenze.Contabil
				nImportoPag = Scadenze.ImportoPag
				lPagato		= Scadenze.Pagato
				dDataPag		= Scadenze.DataPag
				lPortafog	= Scadenze.Portafog
				lSBF			= Scadenze.SBF
				lInsoluto	= Scadenze.Insoluto
				nIdRagg		= Scadenze.IdRagg

				If SEEK(Scadenze.IdRagg, 'Scadenze', 'Id')
					Do WHILE Scadenze.IdRagg = nIdRagg
						If Scadenze.TipoAcc == 'M'
							Replace	Contabil		WITH lContabil, ;
								ImportoPag	WITH nImportoPag, ;
								Pagato		WITH lPagato, ;
								DataPag		WITH dDataPag, ;
								Portafog		WITH lPortafog, ;
								SBF			WITH lSBF, ;
								Insoluto		WITH lInsoluto ;
								IN Scadenze
							Exit
						Endif
						Skip 1 IN Scadenze
					Enddo
				Endif
				Go (nRecNoScad) IN Scadenze
			Endif

			If CURSORGETPROP('Buffering', 'Scadenze') != 1
				Tableupdate(2, .T., 'Scadenze')
			Endif
		Endif
	Endif

	=OnRighe(oRg)

Endfunc

STATIC
Function OnRighe(oRg)

	Local nOldWa

	nOldWa = SELECT(0)

	=OnRigheSaldiContabili(oRg)
	*!*		=OnRigheTotaliIva	   (oRg)

	Select (nOldWa)

Endfunc

STATIC
Function OnRigheSaldiContabili(oRg)

	=SP_OpenTable('Saldi')

	=OnRigheSaldoConto(oRg, 'C')
	=OnRigheSaldoConto(oRg, 'R')

Endfunc

STATIC
Function OnRigheSaldoConto(oRg, cType)

	** cType  --> 'C'/'R'  Competenza/Registrazione

	Local cEsercizio, nMese, nAnno, dDate, cEser
	Local ARRAY aFlds[1]

	If oRg.TipoCau = '9'	&& Rettifica di Bilancio --> comanda la data di competenza
		cType = 'C'			&& anche per saldi per Data Registrazione
	Endif

	dDate = IIF(cType='C', oRg.DataComp, oRg.DataReg)
	cEser = IIF(cType='C', oRg.EsComp,   oRg.EsReg  )

	If EMPTY(dDate)
		Return
	Endif

	Do CASE
		Case oRg.TipoCau = 'E'		&& causale di apertura
			nMese = 00
			nAnno = YEAR(GetInizioEsercizio(dDate))
		Case oRg.TipoCau = 'F'		&& causale di chiusura
			nMese = 13
			nAnno = YEAR(GetFineEsercizio  (dDate))
		Otherwise
			nMese = MONTH(dDate)
			nAnno =  YEAR(dDate)
	Endcase

	Seek cEser+STR(nAnno)+STR(nMese)+oRg.CodConto+oRg.CodiceCF ORDER TAG Codice IN Saldi
	If !FOUND('Saldi')
		=FLOCK('Saldi')
		Seek cEser+STR(nAnno)+STR(nMese)+oRg.CodConto+oRg.CodiceCF ORDER TAG Codice IN Saldi
		If !FOUND('Saldi')
			Insert INTO Saldi (esercizio,anno, mese, CodConto, clifor) VALUES ;
				(cEser, nAnno, nMese, oRg.CodConto, oRg.CodiceCF )
		Endif
		Unlock IN ('Saldi')
	Endif

	If LOCK('Saldi')
		If cType = 'R'
			If oRg.DareFlag='D'
				Replace Saldi.DareR  WITH Saldi.DareR  + oRg.ImportoLit IN Saldi
			Else
				Replace Saldi.AvereR WITH Saldi.AvereR + oRg.ImportoLit IN Saldi
			Endif
		Else
			If oRg.DareFlag='D'
				Replace Saldi.DareC  WITH Saldi.DareC  + oRg.ImportoLit IN Saldi
			Else
				Replace Saldi.AvereC WITH Saldi.AvereC + oRg.ImportoLit IN Saldi
			Endif
		Endif
		Unlock IN Saldi
	Endif
Endfunc

STATIC
Function OnRigheTotaliIva(oRg)
	Local cSeekExp, nIdx
	Local ARRAY aFlds[1]

	If EMPTY(oRg.CodReg) OR !(oRg.TipoRiga $ '24')		&& Ignora righe 3 (Iva Indetraibile) e 5 (Iva in sospensione)
		Return
	Endif

	=SP_OpenTable('Aliquote')
	Seek oRg.CodIva ORDER TAG Codice IN Aliquote
	If Aliquote.FuoriIva
		Return
	Endif

	SP_OpenTable('Registri')
	SP_OpenTable('TotIva'  )

	Seek oRg.CodReg ORDER TAG Codice IN Registri

	cSeekExp = ;
		STR(YEAR(oRg.DataComIva))	+ ;
		Registri.Tipo			 		+ ;
		oRg.CodReg						+ ;
		STR(Aliquote.Aliquota) 		+ ;
		STR(Aliquote.Indetra)		+ ;
		oRg.CodIva						+ ;
		IIF(oRg.FlagCee,'S','N')   + ;
		IIF(oRg.TipoRiga='4','S','N')



	Seek cSeekExp ORDER TAG Codice IN TotIva
	If !FOUND('TotIva')
		=FLOCK('TotIva')
		Seek cSeekExp ORDER TAG Codice IN TotIva
		If !FOUND('TotIva')
			Insert INTO TotIva (				;
				AnnoComp, 						;
				TipoReg, 						;
				Reg, 								;
				Aliquota, 						;
				PercIndetr, 					;
				CodIva, 							;
				FlagCee,							;
				AutoFat			) 				;
				VALUES 				(				;
				YEAR(oRg.DataComIva), 		;
				Registri.Tipo, 				;
				oRg.CodReg, 					;
				Aliquote.Aliquota, 			;
				Aliquote.Indetra, 			;
				oRg.CodIva, 					;
				IIF(oRg.FlagCee,'S','N'), 	;
				IIF(oRg.TipoRiga=='4','S','N'))
		Endif
		Unlock IN TotIva
	Endif

	If LOCK('TotIva')
		Select TotIva
		Scatter MEMO TO aFlds

		*		IF !oRg.SoloIva
		nIdx			= MONTH(oRg.DataComIva) + 7
		aFlds[nIdx]	= aFlds[nIdx]+oRg.Imponibile * IIF(oRg.DareFlag='D',1,-1)
		*		ENDIF
		nIdx				= MONTH(oRg.DataComIva) + 19
		aFlds[nIdx]		= aFlds[nIdx]+oRg.ImportoLit * IIF(oRg.DareFlag='D',1,-1)

		Gather FROM aFlds MEMO
		Unlock IN TotIva
	Endif

Endfunc

