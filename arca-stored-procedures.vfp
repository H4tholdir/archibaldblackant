** Causali contabili
Trigger
Function OnDelCausali()

	Local cCodice

	If TYPE('NoTriggerOnDelCausali') != 'U' OR TYPE('NoTriggerOnDel') != 'U'
		Return .T.
	Endif

	cCodice = Codice

	If EMPTY(cCodice)
		Return .T.
	Endif

	Delete FROM Private!CauAuto WHERE Causale == cCodice

Endfunc

Trigger
Function OnUpdCausali()

	Local cOldCodice, cNewCodice, nOldWa

	If TYPE('NoTriggerOnUpdCausali') != 'U' OR TYPE('NoTriggerOnUpd') != 'U'
		Return .T.
	Endif

	cOldCodice	= CURVAL('Codice')
	If !EMPTY(cOldCodice) AND !EMPTY(Codice) AND !(Codice == cOldCodice)
		nOldWa = SELECT(0)
		cNewCodice	= Codice
		Update Private!CauAuto	SET Causale = cNewCodice WHERE Causale == cOldCodice
		Select (nOldWa)
	Endif

Endfunc

** Valute

Trigger
Function OnUpdCambi()

	Local cOldCodice, cNewCodice
	Local nOldWa

	If TYPE('NoTriggerOnUpdCambi') != 'U' OR TYPE('NoTriggerOnUpd') != 'U'
		Return .T.
	Endif

	Private NoTriggerOnUpd

	cOldCodice	= CURVAL('Codice')
	If !EMPTY(cOldCodice) AND !EMPTY(Codice) AND !(Codice == cOldCodice)

		nOldWa = SELECT(0)

		cNewCodice	= Codice

		Update Private!Ditta		SET Ditta.MonetaDiCo		= cNewCodice	WHERE Ditta.MonetaDiCo		== cOldCodice
		Update Private!ListCfg	SET ListCfg.Valuta		= cNewCodice	WHERE ListCfg.Valuta 		== cOldCodice
		Update Private!Listini	SET Listini.CodValuta	= cNewCodice	WHERE Listini.CodValuta 	== cOldCodice
		Update Private!Teste		SET Teste.CodValuta		= cNewCodice	WHERE Teste.CodValuta 		== cOldCodice
		Update Private!DocTran	SET DocTran.CodValuta	= cNewCodice	WHERE DocTran.CodValuta 	== cOldCodice
		Update Private!Anagrafe	SET Anagrafe.Valuta		= cNewCodice	WHERE Anagrafe.Valuta 		== cOldCodice
		Update Private!DocRig	SET DocRig.Valuta			= cNewCodice	WHERE DocRig.Valuta 			== cOldCodice
		Update Private!DocTes	SET DocTes.Valuta 		= cNewCodice	WHERE DocTes.Valuta 			== cOldCodice
		Update Private!Fixing	SET Fixing.CodValuta		= cNewCodice	WHERE Fixing.CodValuta 		== cOldCodice
		Update Private!Intra		SET Intra.CodVal			= cNewCodice	WHERE Intra.CodVal 			== cOldCodice
		Update Private!Scadenze	SET Scadenze.CodCambio	= cNewCodice	WHERE Scadenze.CodCambio	== cOldCodice

		Select (nOldWa)

	Endif
Endfunc

** ------------------------------------------------------------------------------------------
** Stored Procedures - Funzioni di utilità generale ad uso dei triggers e dei programmi esterni...
** ------------------------------------------------------------------------------------------

* ----------------------------------------------------
* SCOPO  : Incrementa un contatore
* RETURN : [Numeric] Nuovo contatore incrementato
* ----------------------------------------------------
Function NewID()

	Local nOldReprocess
	Local nOldWa, 	 nNewVal, cOldDeleted
	Local cDBFName, cTableName

	nOldReprocess 	= SET('REPROCESS')
	nOldWa 			= SELECT(0)

	Set REPROCESS TO 30
	Set FULLPATH ON
	Set MULTILOCKS ON

	cDBFName   = DBF()
	cTableName = SUBSTR(cDBFName, RAT('\', cDBFName) + 1)
	cTableName = LEFT(cTableName, LEN(cTableName) - 4)

	=SP_OpenTable('Setup_pv', 'Codice')

	cTableName = PADR(cTableName, LEN(Tavola))	&& Tavola == Setup_pv.Tavola

	If SEEK(cTableName)
		=LOCK()
		nNewVal = Val + 1
	Else
		=FLOCK()
		If SEEK(cTableName)
			nNewVal = Val + 1					&& Val == Setup_pv.Val
		Else
			Insert INTO Setup_pv (Tavola) VALUES (cTableName)
			Set DELETED OFF
			Select 0
			Use (cDBFName) AGAIN ALIAS _Calc_Max_ ORDER TAG ID DESC
			nNewVal = ID + 1		&& ID == _Calc_Max_.ID
			Use
			Set DELETED ON
		Endif
	Endif
	Select Setup_pv
	Replace Val WITH nNewVal
	Unlock

	Select (nOldWa)
	Set REPROCESS TO (nOldReprocess)
	Return nNewVal

Endfunc


EXPORTED
Function SP_SafeGoTo(nRec, cAlias)

	** cAlias opzionale
	** Ripristina il numero record precedentemente salvato con RECNO()
	** Gestisce correttamente il caso in cui la tavola sia in EOF() quando chiamo RECNO()
	** solo se nel frattempo non sono stati inseriti records...

	If EMPTY(cAlias)
		cAlias = ALIAS()
	Endif

	If TYPE('nRec') == 'N' .AND. nRec != 0
		If nRec > RECCOUNT(cAlias)							&& se maggiore mi devo riposizionare in EOF()
			If !EOF(cAlias)									&& ... lo faccio solo se non lo sono già (tavola vuota)
				Go BOTTOM IN (cAlias)
				If !EOF(cAlias)
					Skip +1 IN (cAlias)
				Endif
			Endif
		Else
			Go nRec IN (cAlias)
		Endif
	Endif

Endfunc

EXPORTED
Function SP_OpenTable(cTable, cOrder)

	** Apre una tavolo o la rende corrente; se passato imposta anche l'indice corrente.
	** In caso di apertura, sa in Arca97, imposta anche un buffering a 3

	If !USED(cTable)
		Select 0
		Use ('Private!' + cTable) AGAIN
		If TYPE('oApp') == 'O' && Se richiamato da Trigger o Default value tramite ODBC, CursorSetProp sembra non supportato...
			=CURSORSETPROP('Buffering', 3)
		Endif
	Else
		Select (cTable)
	Endif

	If !EMPTY(cOrder)
		Set ORDER TO (cOrder)
	Endif

Endfunc

